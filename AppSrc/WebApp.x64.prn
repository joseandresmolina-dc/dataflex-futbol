37633>>>>>        
37633>>>>>        Move liga.Equipos to iNumEquipos
37634>>>>>        Move liga.EquiposMax to iMaxEquipos
37635>>>>>        
37635>>>>>        If (iNumEquipos < iMaxEquipos) Begin
37637>>>>>               Increment iNumEquipos
37638>>>>>               Move iNumEquipos to liga.EquiposMax
37639>>>>>        End
37639>>>>>>
37639>>>>>        Else Begin
37640>>>>>            Send UserError "No hay sitio en la liga para el nuevo equipo" "ERROR"
37641>>>>>        End
37641>>>>>>
37641>>>>>        
