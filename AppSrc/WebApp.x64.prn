36963>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36964>>>>>    
36964>>>>>    Procedure Construct_Object
36966>>>>>        Handle hoObj
36966>>>>>        
36966>>>>>        Forward Send Construct_Object
36968>>>>>        
36968>>>>>        Set pbSessionCookieHttpOnly to True
36969>>>>>        
36969>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36970>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36971>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36972>>>>>        
36972>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36973>>>>>        Set phoUserDD to hoObj
36974>>>>>        
36974>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36975>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36976>>>>>        Set phoSessionDD to hoObj
36977>>>>>        
36977>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36978>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36979>>>>>        Set phoCrypto to hoObj
36980>>>>>        
36980>>>>>        Property Boolean pbPasswordHashing True
36981>>>>>        
36981>>>>>        Property Boolean pbCreatingNewSession False
36982>>>>>        Property String psLoginName
36983>>>>>        Property String psUserName ""
36984>>>>>        Property Integer piUserRights 0
36985>>>>>    End_Procedure
36986>>>>>    
36986>>>>>    Procedure End_Construct_Object
36988>>>>>        Forward Send End_Construct_Object
36990>>>>>        
36990>>>>>        Handle hoCrypto
36990>>>>>        Integer iFieldLen
36990>>>>>        If (pbPasswordHashing(Self)) Begin
36992>>>>>            Get phoCrypto to hoCrypto
36993>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36996>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36998>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36999>>>>>>
36999>>>>>            End
36999>>>>>>
36999>>>>>        End
36999>>>>>>
36999>>>>>    End_Procedure
37000>>>>>    
37000>>>>>    Function CreateSession String sRemoteAddress Returns String
37002>>>>>        String sSessionKey
37002>>>>>        Integer iErr
37002>>>>>        Boolean bLogWebSession
37002>>>>>        Handle hoSessionDD       
37002>>>>>        Get phoSessionDD to hoSessionDD
37003>>>>>        
37003>>>>>        //  Get session key
37003>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37005>>>>>        
37005>>>>>        Get pbLogWebSession to bLogWebSession
37006>>>>>        If not bLogWebSession Begin
37008>>>>>            Function_Return sSessionKey        
37009>>>>>        End
37009>>>>>>
37009>>>>>
37009>>>>>        //  Store session
37009>>>>>        Send Clear of hoSessionDD
37010>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37011>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37012>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37013>>>>>        Get Request_Validate of hoSessionDD to iErr
37014>>>>>        If (iErr) Begin
37016>>>>>            // this should not happen. If it does its a programming error
37016>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37017>>>>>>
37017>>>>>            Function_Return ""
37018>>>>>        End
37018>>>>>>
37018>>>>>        Send Request_Save of hoSessionDD
37019>>>>>        If (Err) Begin
37021>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37021>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37022>>>>>>
37022>>>>>            Function_Return ""
37023>>>>>        End
37023>>>>>>
37023>>>>>       
37023>>>>>        Function_Return sSessionKey        
37024>>>>>    End_Function
37025>>>>>    
37025>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37027>>>>>        DateTime dtLastAccess dtCurrent
37027>>>>>        TimeSpan tsDiff
37027>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37027>>>>>        Boolean bResult bCreatingNewSession
37027>>>>>        Boolean bLogWebSession bLoadWebApp
37027>>>>>        Integer eLoginMode
37027>>>>>        String sTime
37027>>>>>        Handle hoSessionDD hoUserDD       
37027>>>>>        
37027>>>>>        Move False to bLoadWebApp
37028>>>>>        If (num_arguments >= 2) Begin
37030>>>>>            Move bOptLoadWebApp to bLoadWebApp
37031>>>>>        End
37031>>>>>>
37031>>>>>        
37031>>>>>        Get phoSessionDD to hoSessionDD
37032>>>>>        Get phoUserDD to hoUserDD
37033>>>>>        
37033>>>>>        Get pbLogWebSession to bLogWebSession
37034>>>>>        Get peLoginMode to eLoginMode
37035>>>>>        
37035>>>>>        // for this object, you can only disable logging if login completely is disabled
37035>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37037>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37038>>>>>>
37038>>>>>            Function_Return False
37039>>>>>        End
37039>>>>>>
37039>>>>>
37039>>>>>        //  Clear session properties
37039>>>>>        Set psSessionKey to ""
37040>>>>>        Send UpdateSessionProperties True
37041>>>>>        
37041>>>>>        If not bLogWebSession Begin
37043>>>>>            Forward Get ValidateSession sSessionKey to bResult
37045>>>>>            Function_Return bResult
37046>>>>>        End        
37046>>>>>>
37046>>>>>        
37046>>>>>        Move False to bResult
37047>>>>>        Get piSessionTimeout to iSessionTimeout 
37048>>>>>        
37048>>>>>        //  Check if session exists
37048>>>>>        Send Clear of hoSessionDD
37049>>>>>        Move sSessionKey to WebAppSession.SessionKey
37050>>>>>        Send Find of hoSessionDD EQ Index.1
37051>>>>>            
37051>>>>>        If (Found) Begin
37053>>>>>            //  Calculate timespan between now and last access time
37053>>>>>            Move (CurrentDateTime()) to dtCurrent
37054>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37055>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37056>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37057>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37058>>>>>            
37058>>>>>            //  Check if session didn't time out
37058>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37060>>>>>                Forward Get ValidateSession sSessionKey to bResult
37062>>>>>                   
37062>>>>>                If (bResult) Begin
37064>>>>>                    //  Update session record
37064>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37065>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37066>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37067>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37068>>>>>                    Get Request_Validate of hoSessionDD to iErr
37069>>>>>                    If (iErr) Begin
37071>>>>>                        // this should not happen. If it does its a programming error
37071>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37072>>>>>>
37072>>>>>                        Function_Return False
37073>>>>>                    End
37073>>>>>>
37073>>>>>                    Send Request_Save of hoSessionDD
37074>>>>>                    
37074>>>>>                    //  Update user properties
37074>>>>>                    Send UpdateSessionProperties False
37075>>>>>                End
37075>>>>>>
37075>>>>>            End
37075>>>>>>
37075>>>>>            Else Begin
37076>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37076>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37077>>>>>                
37077>>>>>                If (not(bCreatingNewSession)) Begin
37079>>>>>                    If (not(bLoadWebApp)) Begin
37081>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37082>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37083>>>>>>
37083>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37084>>>>>                    End
37084>>>>>>
37084>>>>>                    Else Begin
37085>>>>>                        Set pbCreatingNewSession to True                    
37086>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37087>>>>>                        Set pbCreatingNewSession to False                        
37088>>>>>                    End
37088>>>>>>
37088>>>>>                End
37088>>>>>>
37088>>>>>            End
37088>>>>>>
37088>>>>>        End
37088>>>>>>
37088>>>>>        Else Begin
37089>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37090>>>>>>
37090>>>>>        End
37090>>>>>>
37090>>>>>        
37090>>>>>        Function_Return bResult
37091>>>>>    End_Function
37092>>>>>    
37092>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37094>>>>>        If (not(pbPasswordHashing(Self))) Begin
37096>>>>>            Move sPassword to sHash
37097>>>>>            Function_Return True
37098>>>>>        End
37098>>>>>>
37098>>>>>        
37098>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37100>>>>>            Function_Return False
37101>>>>>        End
37101>>>>>>
37101>>>>>        Move ("V1$" + sHash) to sHash
37102>>>>>        Function_Return True
37103>>>>>    End_Function
37104>>>>>    
37104>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37106>>>>>        If (not(pbPasswordHashing(Self))) Begin
37108>>>>>            Move False to bShouldUpgrade
37109>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37110>>>>>        End
37110>>>>>>
37110>>>>>        
37110>>>>>        String sVersion
37110>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37111>>>>>        If (sVersion = "V1$") Begin
37113>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37116>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37117>>>>>        End
37117>>>>>>
37117>>>>>        Else Begin
37118>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37121>>>>>            Function_Return False
37122>>>>>        End
37122>>>>>>
37122>>>>>    End_Function
37123>>>>>    
37123>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37125>>>>>        Handle hoUserDD
37125>>>>>        Integer iErr
37125>>>>>        Get phoUserDD to hoUserDD
37126>>>>>        
37126>>>>>        //  Find the user
37126>>>>>        Send Clear of hoUserDD
37127>>>>>        Move sLoginName to WebAppUser.LoginName
37128>>>>>        Send Find of hoUserDD EQ Index.1
37129>>>>>        If (Found) Begin
37131>>>>>            Send Clear of hoUserDD
37132>>>>>            Function_Return False
37133>>>>>        End
37133>>>>>>
37133>>>>>        
37133>>>>>        Send Clear of hoUserDD
37134>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37135>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37136>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37138>>>>>            Send Clear of hoUserDD
37139>>>>>            Function_Return False
37140>>>>>        End
37140>>>>>>
37140>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37141>>>>>        Get Request_Validate of hoUserDD to iErr
37142>>>>>        If (iErr) Begin
37144>>>>>            Send Clear of hoUserDD
37145>>>>>            Function_Return False
37146>>>>>        End
37146>>>>>>
37146>>>>>        
37146>>>>>        Send Request_Save of hoUserDD
37147>>>>>        Function_Return (not(Err))
37148>>>>>    End_Function
37149>>>>>    
37149>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37151>>>>>        String sSessionKey sUserPassword
37151>>>>>        Handle hoSessionDD hoUserDD
37151>>>>>        Boolean bMatch bUpgrade
37151>>>>>        
37151>>>>>        Get phoSessionDD to hoSessionDD
37152>>>>>        Get phoUserDD to hoUserDD
37153>>>>>        Integer iErr eLoginMode
37153>>>>>        
37153>>>>>        // Refind session record
37153>>>>>        Get psSessionKey to sSessionKey
37154>>>>>        Send Clear of hoSessionDD
37155>>>>>        Move sSessionKey to WebAppSession.SessionKey
37156>>>>>        Send Find of hoSessionDD EQ Index.1
37157>>>>>        
37157>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37159>>>>>            Get peLoginMode to eLoginMode
37160>>>>>            
37160>>>>>            //  Find the user
37160>>>>>            Move sLoginName to WebAppUser.LoginName
37161>>>>>            Send Find of hoUserDD EQ Index.1
37162>>>>>            
37162>>>>>            // Check username and password
37162>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37164>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37165>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37166>>>>>                
37166>>>>>                If (bMatch) Begin
37168>>>>>                    // Store the login
37168>>>>>                    If (bUpgrade) Begin
37170>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37171>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37174>>>>>                    End
37174>>>>>>
37174>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37175>>>>>                    Get Request_Validate of hoSessionDD to iErr
37176>>>>>                    If (iErr) Begin
37178>>>>>                        // this should not happen. If it does its a programming error
37178>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37179>>>>>>
37179>>>>>                        Function_Return False
37180>>>>>                    End
37180>>>>>>
37180>>>>>                    
37180>>>>>                    Send Request_Save of hoSessionDD
37181>>>>>                    
37181>>>>>                    // Update session properties
37181>>>>>                    Send UpdateSessionProperties False
37182>>>>>                    Send NotifyChangeRights
37183>>>>>                    Function_Return True
37184>>>>>                End
37184>>>>>>
37184>>>>>                Else Begin
37185>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37185>>>>>                    Send Clear of hoUserDD
37186>>>>>                End
37186>>>>>>
37186>>>>>            End
37186>>>>>>
37186>>>>>            Else Begin
37187>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37187>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37188>>>>>            End
37188>>>>>>
37188>>>>>        End
37188>>>>>>
37188>>>>>        Else Begin
37189>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37189>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37190>>>>>        End
37190>>>>>>
37190>>>>>          
37190>>>>>        Function_Return False
37191>>>>>    End_Function
37192>>>>>    
37192>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37194>>>>>        Handle hoUserDD
37194>>>>>        Integer iErr
37194>>>>>        Get phoUserDD to hoUserDD
37195>>>>>        
37195>>>>>        //  Find the user
37195>>>>>        Send Clear of hoUserDD
37196>>>>>        Move sLoginName to WebAppUser.LoginName
37197>>>>>        Send Find of hoUserDD EQ Index.1
37198>>>>>        If (not(Found)) Begin
37200>>>>>            Send Clear of hoUserDD
37201>>>>>            Function_Return False
37202>>>>>        End
37202>>>>>>
37202>>>>>        
37202>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37204>>>>>            Send Clear of hoUserDD
37205>>>>>            Function_Return False
37206>>>>>        End
37206>>>>>>
37206>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37207>>>>>        Get Request_Validate of hoUserDD to iErr
37208>>>>>        If (iErr) Begin
37210>>>>>            Send Clear of hoUserDD
37211>>>>>            Function_Return False
37212>>>>>        End
37212>>>>>>
37212>>>>>        
37212>>>>>        Send Request_Save of hoUserDD
37213>>>>>        Function_Return (not(Err))
37214>>>>>    End_Function
37215>>>>>    
37215>>>>>    Function IsLoggedIn Returns Boolean
37217>>>>>        String sLoginName
37217>>>>>        Boolean bLogWebSession bLoggedIn
37217>>>>>        
37217>>>>>        Get pbLogWebSession to bLogWebSession
37218>>>>>        If not bLogWebSession Begin
37220>>>>>            Forward Get IsLoggedIn to bLoggedIn
37222>>>>>            Function_Return bLoggedIn
37223>>>>>        End
37223>>>>>>
37223>>>>>        
37223>>>>>        Get psLoginName to sLoginName
37224>>>>>        
37224>>>>>        Function_Return (sLoginName <> "")
37225>>>>>    End_Function
37226>>>>>    
37226>>>>>    
37226>>>>>    //
37226>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37226>>>>>    // update properties based on the session and user data. Augment this function to update 
37226>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37226>>>>>    // the right records when this procedure is called.
37226>>>>>    //
37226>>>>>    // Params:
37226>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37226>>>>>    //
37226>>>>>    Procedure UpdateSessionProperties Boolean bClear
37228>>>>>        Handle hoUserDD
37228>>>>>        
37228>>>>>        Get phoUserDD to hoUserDD
37229>>>>>        
37229>>>>>        //  Update user properties
37229>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37231>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37232>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37233>>>>>            Set piUserRights to WebAppUser.Rights
37234>>>>>            
37234>>>>>            Send OnSessionPropertiesSet 
37235>>>>>        End
37235>>>>>>
37235>>>>>        Else Begin
37236>>>>>            Set psUsername to ""
37237>>>>>            Set psLoginName to ""
37238>>>>>            Set piUserRights to 0
37239>>>>>            
37239>>>>>            Send OnSessionPropertiesClear
37240>>>>>        End
37240>>>>>>
37240>>>>>    End_Procedure
37241>>>>>    
37241>>>>>    Procedure OnSessionPropertiesSet
37243>>>>>        //  Empty event stub
37243>>>>>    End_Procedure
37244>>>>>    
37244>>>>>    Procedure OnSessionPropertiesClear
37246>>>>>        //  Empty event stub
37246>>>>>    End_Procedure
37247>>>>>    
37247>>>>>    Procedure EndSession
37249>>>>>        Integer iErr
37249>>>>>        Boolean bLogWebSession
37249>>>>>        Handle hoSessionDD       
37249>>>>>        
37249>>>>>        Get phoSessionDD to hoSessionDD
37250>>>>>        Get pbLogWebSession to bLogWebSession
37251>>>>>        If not bLogWebSession Begin
37253>>>>>            Forward Send EndSession
37255>>>>>            Procedure_Return
37256>>>>>        End
37256>>>>>>
37256>>>>>            
37256>>>>>        //  Check if session exists
37256>>>>>        Send Clear of hoSessionDD
37257>>>>>        Get psSessionKey to WebAppSession.SessionKey
37258>>>>>        
37258>>>>>        Send Find of hoSessionDD EQ Index.1
37259>>>>>        If (Found) Begin
37261>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37262>>>>>            Get Request_Validate of hoSessionDD to iErr
37263>>>>>            If (iErr) Begin
37265>>>>>                // this should not happen. If it does its a programming error
37265>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37266>>>>>>
37266>>>>>                Procedure_Return
37267>>>>>            End
37267>>>>>>
37267>>>>>            Send Request_Save of hoSessionDD
37268>>>>>        End
37268>>>>>>
37268>>>>>    End_Procedure
37269>>>>>
37269>>>>>End_Class
