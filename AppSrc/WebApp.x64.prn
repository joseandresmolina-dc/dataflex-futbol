37357>>>    Procedure DoLogin
37360>>>        String sLoginName sPassword sPrevStateHash
37360>>>        Boolean bResult
37360>>>        
37360>>>        WebGet psValue of oLoginName to sLoginName
37361>>>        WebGet psValue of oPassword to sPassword
37362>>>        
37362>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37363>>>        
37363>>>        If (bResult) Begin
37365>>>            Send Hide of oLogin
37366>>>            Send ShowHeader of ghoWebApp
37367>>>            WebSet psCSSClass of ghoWebApp to ""
37368>>>            
37368>>>            WebGet psPrevStateHash to sPrevStateHash
37369>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37370>>>            
37370>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37370>>>            WebSet psValue of oLoginName to ""
37371>>>            WebSet psValue of oPassword  to ""
37372>>>            WebSet pbVisible of oWarning to False
37373>>>        End
37373>>>>
37373>>>        Else Begin
37374>>>            WebSet pbVisible of oWarning to True
37375>>>        End
37375>>>>
37375>>>    End_Procedure
37376>>>    
37376>>>    Procedure OnSubmit
37379>>>        Send DoLogin
37380>>>    End_Procedure
37381>>>    
37381>>>    Procedure OnLoad
37384>>>        String sPrevStateHash sView
37384>>>        
37384>>>        Forward Send OnLoad
37386>>>        
37386>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37386>>>        Get StateHash of ghoWebApp to sPrevStateHash
37387>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37388>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37390>>>            WebSet psPrevStateHash to sPrevStateHash
37391>>>        End
37391>>>>
37391>>>        
37391>>>    End_Procedure
37392>>>    
