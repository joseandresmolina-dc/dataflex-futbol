38361>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38364>>>        WebSet pbRender of oNewButton to True
38365>>>        WebSet pbRender of oDetailButton to True
38366>>>
38366>>>        Case Begin
38366>>>            Case (NavigateData.eNavigateType = nfFromParent)
38368>>>                // If from parent, this is a constrained drill down
38368>>>                Case Break
38369>>>
38369>>>            Case (NavigateData.eNavigateType = nfFromChild)
38372>>>                // If from child, this is a probably a parent lookup from a Zoom
38372>>>                Case Break
38373>>>
38373>>>            Case (NavigateData.eNavigateType = nfFromMain)
38376>>>                // If from main, this is a probably a main-file lookup from a Zoom
38376>>>                WebSet pbRender of oDetailButton to False
38377>>>                Case Break
38378>>>
38378>>>            Case Else // must be nfUndefined
38378>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38378>>>
38378>>>        Case End
38378>>>
38378>>>    End_Procedure
38379>>>
38379>>>
38379>>>End_Object 
