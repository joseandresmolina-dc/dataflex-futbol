36776>>>>>>>    Function RandomBuffer UInteger uiSize Returns UChar[]
36778>>>>>>>        UChar[] ucaBuffer
36779>>>>>>>        Move (ResizeArray(ucaBuffer, uiSize)) to ucaBuffer
36780>>>>>>>        If (CNG_BCryptGenRandom(0, AddressOf(ucaBuffer), uiSize, |CI$00000002 /*BCRYPT_USE_SYSTEM_PREFERRED_RNG*/)) Begin
36782>>>>>>>            Error 8710 "Failed to create random buffer."
36783>>>>>>>>
36783>>>>>>>        End
36783>>>>>>>>
36783>>>>>>>        Function_Return ucaBuffer
36784>>>>>>>    End_Function
36785>>>>>>>    
36785>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
36787>>>>>>>        Integer iErr
36787>>>>>>>        Pointer pBase64
36787>>>>>>>        String sBase64
36787>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
36788>>>>>>>        If (not(pBase64)) Begin
36790>>>>>>>            Function_Return sBase64
36791>>>>>>>        End
36791>>>>>>>>
36791>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36792>>>>>>>        Move (Free(pBase64)) to iErr
36793>>>>>>>        Function_Return sBase64
36794>>>>>>>    End_Function
36795>>>>>>>    
36795>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36797>>>>>>>        Integer iLen
36797>>>>>>>        Pointer pBase64
36797>>>>>>>        UChar[] ucaBuffer
36798>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36799>>>>>>>        If (not(pBase64)) Begin
36801>>>>>>>            Function_Return ucaBuffer
36802>>>>>>>        End
36802>>>>>>>>
36802>>>>>>>        
36802>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36803>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36804>>>>>>>        Move (Free(pBase64)) to iLen
36805>>>>>>>        Function_Return ucaBuffer
36806>>>>>>>    End_Function
36807>>>>>>>    
36807>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36809>>>>>>>        Boolean bOk bRequireTimeCost
36809>>>>>>>        UChar[] ucaHash
36810>>>>>>>        
36810>>>>>>>        Case Begin
36810>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36812>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36813>>>>>>>                If (not(bOk)) Function_Return False
36816>>>>>>>                
36816>>>>>>>                Move True to bRequireTimeCost
36817>>>>>>>                Case Break
36818>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36821>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36822>>>>>>>                If (not(bOk)) Function_Return False
36825>>>>>>>                
36825>>>>>>>                Move True to bRequireTimeCost
36826>>>>>>>                Case Break
36827>>>>>>>            Case Else
36827>>>>>>>                Error 8710 "Invalid algorithm selected."
36828>>>>>>>>
36828>>>>>>>                Function_Return False
36829>>>>>>>        Case End
36829>>>>>>>        
36829>>>>>>>        String sSalt
36829>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36830>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36833>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36834>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36837>>>>>>>        
36837>>>>>>>        If (bRequireTimeCost) Begin
36839>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36840>>>>>>>        End
36840>>>>>>>>
36840>>>>>>>        Else Begin
36841>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36842>>>>>>>        End
36842>>>>>>>>
36842>>>>>>>        
36842>>>>>>>        Function_Return bOk
36843>>>>>>>    End_Function
36844>>>>>>>    
36844>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36846>>>>>>>        UChar[] ucaSalt
36847>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36848>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36851>>>>>>>        
36851>>>>>>>        If (num_arguments > 4) Begin
36853>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36854>>>>>>>        End
36854>>>>>>>>
36854>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36855>>>>>>>    End_Function
36856>>>>>>>    
36856>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36858>>>>>>>        Boolean bRequiresTimeCost
36858>>>>>>>        UInteger uiAlgo uiTimeCost
36858>>>>>>>        Integer iBegin iEnd
36858>>>>>>>        String sSalt
36858>>>>>>>        
36858>>>>>>>        Move 1 to iBegin
36859>>>>>>>        
36859>>>>>>>        // Parse Algo
36859>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36860>>>>>>>        If (not(iEnd)) Function_Return False
36863>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36864>>>>>>>        
36864>>>>>>>        // Parse Salt
36864>>>>>>>        Move (iEnd + 1) to iBegin
36865>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36866>>>>>>>        If (not(iEnd)) Function_Return False
36869>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36870>>>>>>>        
36870>>>>>>>        Case Begin
36870>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36872>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36875>>>>>>>                Move True to bRequiresTimeCost
36876>>>>>>>                Case Break
36877>>>>>>>            Case Else
36877>>>>>>>                Error 8710 "Invalid algorithm selected."
36878>>>>>>>>
36878>>>>>>>                Function_Return False
36879>>>>>>>        Case End
36879>>>>>>>        
36879>>>>>>>        // Parse optional timecost
36879>>>>>>>        If (bRequiresTimeCost) Begin
36881>>>>>>>            Move (iEnd + 1) to iBegin
36882>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36883>>>>>>>            If (not(iEnd)) Function_Return False
36886>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36887>>>>>>>        End
36887>>>>>>>>
36887>>>>>>>        
36887>>>>>>>        // Parse rest hash
36887>>>>>>>        Move (iEnd + 1) to iBegin
36888>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36889>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36892>>>>>>>        
36892>>>>>>>        // Base64Decode
36892>>>>>>>        UChar[] ucaSalt
36893>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36894>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36897>>>>>>>        
36897>>>>>>>        // Create new hash
36897>>>>>>>        String sNewHash
36897>>>>>>>        If (bRequiresTimeCost) Begin
36899>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36901>>>>>>>                Function_Return False 
36902>>>>>>>            End
36902>>>>>>>>
36902>>>>>>>        End
36902>>>>>>>>
36902>>>>>>>        Else Begin
36903>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36905>>>>>>>                Function_Return False 
36906>>>>>>>            End
36906>>>>>>>>
36906>>>>>>>        End
36906>>>>>>>>
36906>>>>>>>        Function_Return (sNewHash = sHash)
36907>>>>>>>    End_Function
36908>>>>>>>    
36908>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36910>>>>>>>        Boolean bRequireTimeCost
36910>>>>>>>        UBigInt ullSize
36910>>>>>>>        UChar[] ucaSalt
36911>>>>>>>        String sSalt
36911>>>>>>>        
36911>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36912>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36913>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36916>>>>>>>        
36916>>>>>>>        Case Begin
36916>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36918>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36919>>>>>>>                Move True to bRequireTimeCost
36920>>>>>>>                Case Break
36921>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36924>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36925>>>>>>>                Move True to bRequireTimeCost
36926>>>>>>>                Case Break
36927>>>>>>>            Case Else
36927>>>>>>>                Error 8710 "Invalid algorithm selected."
36928>>>>>>>>
36928>>>>>>>                Function_Return 0
36929>>>>>>>        Case End
36929>>>>>>>        
36929>>>>>>>        // calculate base64 in a non-floating-manner
36929>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36930>>>>>>>        
36930>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36931>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36932>>>>>>>        If (bRequireTimeCost) Begin
36934>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36935>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36936>>>>>>>        End
36936>>>>>>>>
36936>>>>>>>        Else Begin
36937>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36938>>>>>>>        End
36938>>>>>>>>
36938>>>>>>>        
36938>>>>>>>        Function_Return ullSize
36939>>>>>>>    End_Function
36940>>>>>>>End_Class
36941>>>>>>>
36941>>>>>>>Class cPasswordHasher is a cObject
36942>>>>>>>    
36942>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36943>>>>>>>    
36943>>>>>>>    Procedure Construct_Object
36945>>>>>>>        Forward Send Construct_Object
36947>>>>>>>        
36947>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36948>>>>>>>        Property UInteger   puiSaltSize         16
36949>>>>>>>        
36949>>>>>>>        Property UInteger   puiOptTimeCost      420000
36950>>>>>>>    End_Procedure
36951>>>>>>>    
36951>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36953>>>>>>>        Boolean bOk
36953>>>>>>>        UInteger uiAlgo
36953>>>>>>>        Get peAlgorithm to uiAlgo
36954>>>>>>>        
36954>>>>>>>        Case Begin
36954>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36956>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36959>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36960>>>>>>>                Case Break
36961>>>>>>>            Case Else
36961>>>>>>>                Error 8710 "Invalid algorithm selected."
36962>>>>>>>>
36962>>>>>>>                Function_Return False
36963>>>>>>>        Case End
36963>>>>>>>        
36963>>>>>>>        Function_Return bOk
36964>>>>>>>    End_Function
36965>>>>>>>    
36965>>>>>>>    Function RequiredBufferSize Returns UBigInt
36967>>>>>>>        UBigInt ullSize
36967>>>>>>>        UInteger uiAlgo
36967>>>>>>>        Get peAlgorithm to uiAlgo
36968>>>>>>>        
36968>>>>>>>        Case Begin
36968>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36970>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36973>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36974>>>>>>>                Case Break
36975>>>>>>>            Case Else
36975>>>>>>>                Error 8710 "Invalid algorithm selected."
36976>>>>>>>>
36976>>>>>>>                Function_Return 0
36977>>>>>>>        Case End
36977>>>>>>>        
36977>>>>>>>        Function_Return ullSize
36978>>>>>>>    End_Function
36979>>>>>>>
36979>>>>>>>End_Class
