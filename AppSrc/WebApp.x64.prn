37374>>>    Procedure DoLogin
37377>>>        String sLoginName sPassword sPrevStateHash
37377>>>        Boolean bResult
37377>>>        
37377>>>        WebGet psValue of oLoginName to sLoginName
37378>>>        WebGet psValue of oPassword to sPassword
37379>>>        
37379>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37380>>>        
37380>>>        If (bResult) Begin
37382>>>            Send Hide of oLogin
37383>>>            Send ShowHeader of ghoWebApp
37384>>>            WebSet psCSSClass of ghoWebApp to ""
37385>>>            
37385>>>            WebGet psPrevStateHash to sPrevStateHash
37386>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37387>>>            
37387>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37387>>>            WebSet psValue of oLoginName to ""
37388>>>            WebSet psValue of oPassword  to ""
37389>>>            WebSet pbVisible of oWarning to False
37390>>>        End
37390>>>>
37390>>>        Else Begin
37391>>>            WebSet pbVisible of oWarning to True
37392>>>        End
37392>>>>
37392>>>    End_Procedure
37393>>>    
37393>>>    Procedure OnSubmit
37396>>>        Send DoLogin
37397>>>    End_Procedure
