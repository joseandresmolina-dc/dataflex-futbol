38949>>>        WebSet pbRender of oSaveBtn to False
38950>>>        WebSet pbRender of oCancelChangesBtn to False
38951>>>        WebSet pbRender of oDeleteBtn to False
38952>>>
38952>>>        If (NavigateData.bReadOnly) Begin
38954>>>            WebSet pbRender of oEditBtn to True
38955>>>        End
38955>>>>
38955>>>        Else Begin
38956>>>            WebSet pbRender of oSaveBtn to True
38957>>>            WebSet pbRender of oCancelChangesBtn to True
38958>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38959>>>        End
38959>>>>
38959>>>    End_Procedure
