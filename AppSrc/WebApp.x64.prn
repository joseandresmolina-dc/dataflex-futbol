36766>>>>>>>>
36766>>>>>>>        End
36766>>>>>>>>
36766>>>>>>>        Function_Return ucaBuffer
36767>>>>>>>    End_Function
36768>>>>>>>    
36768>>>>>>>    Function Base64EncodeArr UChar[] ucaBuffer Returns String
36770>>>>>>>        Integer iErr
36770>>>>>>>        Pointer pBase64
36770>>>>>>>        String sBase64
36770>>>>>>>        Move (Base64Encode(AddressOf(ucaBuffer), SizeOfArray(ucaBuffer))) to pBase64
36771>>>>>>>        If (not(pBase64)) Begin
36773>>>>>>>            Function_Return sBase64
36774>>>>>>>        End
36774>>>>>>>>
36774>>>>>>>        Move (PointerToString(pBase64)) to sBase64
36775>>>>>>>        Move (Free(pBase64)) to iErr
36776>>>>>>>        Function_Return sBase64
36777>>>>>>>    End_Function
36778>>>>>>>    
36778>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36780>>>>>>>        Integer iLen
36780>>>>>>>        Pointer pBase64
36780>>>>>>>        UChar[] ucaBuffer
36781>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36782>>>>>>>        If (not(pBase64)) Begin
36784>>>>>>>            Function_Return ucaBuffer
36785>>>>>>>        End
36785>>>>>>>>
36785>>>>>>>        
36785>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36786>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36787>>>>>>>        Move (Free(pBase64)) to iLen
36788>>>>>>>        Function_Return ucaBuffer
36789>>>>>>>    End_Function
36790>>>>>>>    
36790>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36792>>>>>>>        Boolean bOk bRequireTimeCost
36792>>>>>>>        UChar[] ucaHash
36793>>>>>>>        
36793>>>>>>>        Case Begin
36793>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36795>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36796>>>>>>>                If (not(bOk)) Function_Return False
36799>>>>>>>                
36799>>>>>>>                Move True to bRequireTimeCost
36800>>>>>>>                Case Break
36801>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36804>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36805>>>>>>>                If (not(bOk)) Function_Return False
36808>>>>>>>                
36808>>>>>>>                Move True to bRequireTimeCost
36809>>>>>>>                Case Break
36810>>>>>>>            Case Else
36810>>>>>>>                Error 8710 "Invalid algorithm selected."
36811>>>>>>>>
36811>>>>>>>                Function_Return False
36812>>>>>>>        Case End
36812>>>>>>>        
36812>>>>>>>        String sSalt
36812>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36813>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36816>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36817>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36820>>>>>>>        
36820>>>>>>>        If (bRequireTimeCost) Begin
36822>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36823>>>>>>>        End
36823>>>>>>>>
36823>>>>>>>        Else Begin
36824>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36825>>>>>>>        End
36825>>>>>>>>
36825>>>>>>>        
36825>>>>>>>        Function_Return bOk
36826>>>>>>>    End_Function
36827>>>>>>>    
36827>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36829>>>>>>>        UChar[] ucaSalt
36830>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36831>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36834>>>>>>>        
36834>>>>>>>        If (num_arguments > 4) Begin
36836>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36837>>>>>>>        End
36837>>>>>>>>
36837>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36838>>>>>>>    End_Function
36839>>>>>>>    
36839>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36841>>>>>>>        Boolean bRequiresTimeCost
36841>>>>>>>        UInteger uiAlgo uiTimeCost
36841>>>>>>>        Integer iBegin iEnd
36841>>>>>>>        String sSalt
36841>>>>>>>        
36841>>>>>>>        Move 1 to iBegin
36842>>>>>>>        
36842>>>>>>>        // Parse Algo
36842>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36843>>>>>>>        If (not(iEnd)) Function_Return False
36846>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36847>>>>>>>        
36847>>>>>>>        // Parse Salt
36847>>>>>>>        Move (iEnd + 1) to iBegin
36848>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36849>>>>>>>        If (not(iEnd)) Function_Return False
36852>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36853>>>>>>>        
36853>>>>>>>        Case Begin
36853>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36855>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36858>>>>>>>                Move True to bRequiresTimeCost
36859>>>>>>>                Case Break
36860>>>>>>>            Case Else
36860>>>>>>>                Error 8710 "Invalid algorithm selected."
36861>>>>>>>>
36861>>>>>>>                Function_Return False
36862>>>>>>>        Case End
36862>>>>>>>        
36862>>>>>>>        // Parse optional timecost
36862>>>>>>>        If (bRequiresTimeCost) Begin
36864>>>>>>>            Move (iEnd + 1) to iBegin
36865>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36866>>>>>>>            If (not(iEnd)) Function_Return False
36869>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36870>>>>>>>        End
36870>>>>>>>>
36870>>>>>>>        
36870>>>>>>>        // Parse rest hash
36870>>>>>>>        Move (iEnd + 1) to iBegin
36871>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36872>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36875>>>>>>>        
36875>>>>>>>        // Base64Decode
36875>>>>>>>        UChar[] ucaSalt
36876>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36877>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36880>>>>>>>        
36880>>>>>>>        // Create new hash
36880>>>>>>>        String sNewHash
36880>>>>>>>        If (bRequiresTimeCost) Begin
36882>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36884>>>>>>>                Function_Return False 
36885>>>>>>>            End
36885>>>>>>>>
36885>>>>>>>        End
36885>>>>>>>>
36885>>>>>>>        Else Begin
36886>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36888>>>>>>>                Function_Return False 
36889>>>>>>>            End
36889>>>>>>>>
36889>>>>>>>        End
36889>>>>>>>>
36889>>>>>>>        Function_Return (sNewHash = sHash)
36890>>>>>>>    End_Function
36891>>>>>>>    
36891>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36893>>>>>>>        Boolean bRequireTimeCost
36893>>>>>>>        UBigInt ullSize
36893>>>>>>>        UChar[] ucaSalt
36894>>>>>>>        String sSalt
36894>>>>>>>        
36894>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36895>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36896>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36899>>>>>>>        
36899>>>>>>>        Case Begin
36899>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36901>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36902>>>>>>>                Move True to bRequireTimeCost
36903>>>>>>>                Case Break
36904>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36907>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36908>>>>>>>                Move True to bRequireTimeCost
36909>>>>>>>                Case Break
36910>>>>>>>            Case Else
36910>>>>>>>                Error 8710 "Invalid algorithm selected."
36911>>>>>>>>
36911>>>>>>>                Function_Return 0
36912>>>>>>>        Case End
36912>>>>>>>        
36912>>>>>>>        // calculate base64 in a non-floating-manner
36912>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36913>>>>>>>        
36913>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36914>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36915>>>>>>>        If (bRequireTimeCost) Begin
36917>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36918>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36919>>>>>>>        End
36919>>>>>>>>
36919>>>>>>>        Else Begin
36920>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36921>>>>>>>        End
36921>>>>>>>>
36921>>>>>>>        
36921>>>>>>>        Function_Return ullSize
36922>>>>>>>    End_Function
36923>>>>>>>End_Class
36924>>>>>>>
36924>>>>>>>Class cPasswordHasher is a cObject
36925>>>>>>>    
36925>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36926>>>>>>>    
36926>>>>>>>    Procedure Construct_Object
36928>>>>>>>        Forward Send Construct_Object
36930>>>>>>>        
36930>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36931>>>>>>>        Property UInteger   puiSaltSize         16
36932>>>>>>>        
36932>>>>>>>        Property UInteger   puiOptTimeCost      420000
36933>>>>>>>    End_Procedure
36934>>>>>>>    
36934>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36936>>>>>>>        Boolean bOk
36936>>>>>>>        UInteger uiAlgo
36936>>>>>>>        Get peAlgorithm to uiAlgo
36937>>>>>>>        
36937>>>>>>>        Case Begin
36937>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36939>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36942>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36943>>>>>>>                Case Break
36944>>>>>>>            Case Else
36944>>>>>>>                Error 8710 "Invalid algorithm selected."
36945>>>>>>>>
36945>>>>>>>                Function_Return False
36946>>>>>>>        Case End
36946>>>>>>>        
36946>>>>>>>        Function_Return bOk
36947>>>>>>>    End_Function
36948>>>>>>>    
36948>>>>>>>    Function RequiredBufferSize Returns UBigInt
36950>>>>>>>        UBigInt ullSize
36950>>>>>>>        UInteger uiAlgo
36950>>>>>>>        Get peAlgorithm to uiAlgo
36951>>>>>>>        
36951>>>>>>>        Case Begin
36951>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36953>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36956>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36957>>>>>>>                Case Break
36958>>>>>>>            Case Else
36958>>>>>>>                Error 8710 "Invalid algorithm selected."
36959>>>>>>>>
36959>>>>>>>                Function_Return 0
36960>>>>>>>        Case End
36960>>>>>>>        
36960>>>>>>>        Function_Return ullSize
36961>>>>>>>    End_Function
36962>>>>>>>
36962>>>>>>>End_Class
