37774>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37777>>>        Case Begin
37777>>>            Case (NavigateData.eNavigateType = nfFromMain)
37779>>>                // If from main, this is a propbably a main file Select to Zoom.
37779>>>                Case Break
37780>>>
37780>>>            Case (NavigateData.eNavigateType = nfFromParent)
37783>>>                // If from parent, this is a constrained drill down.
37783>>>                Case Break
37784>>>
37784>>>            Case (NavigateData.eNavigateType = nfFromChild)
37787>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37787>>>                Case Break
37788>>>
37788>>>            Case Else // must be nfUndefined
37788>>>
37788>>>        Case End
37788>>>
37788>>>        Send SetActionButtons
37789>>>
37789>>>    End_Procedure
37790>>>
37790>>>End_Object 
