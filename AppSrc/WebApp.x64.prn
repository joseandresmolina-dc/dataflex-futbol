37034>>>>>    
37034>>>>>    Function CreateSession String sRemoteAddress Returns String
37036>>>>>        String sSessionKey
37036>>>>>        Integer iErr
37036>>>>>        Boolean bLogWebSession
37036>>>>>        Handle hoSessionDD       
37036>>>>>        Get phoSessionDD to hoSessionDD
37037>>>>>        
37037>>>>>        //  Get session key
37037>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37039>>>>>        
37039>>>>>        Get pbLogWebSession to bLogWebSession
37040>>>>>        If not bLogWebSession Begin
37042>>>>>            Function_Return sSessionKey        
37043>>>>>        End
37043>>>>>>
37043>>>>>
37043>>>>>        //  Store session
37043>>>>>        Send Clear of hoSessionDD
37044>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37045>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37046>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37047>>>>>        Get Request_Validate of hoSessionDD to iErr
37048>>>>>        If (iErr) Begin
37050>>>>>            // this should not happen. If it does its a programming error
37050>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37051>>>>>>
37051>>>>>            Function_Return ""
37052>>>>>        End
37052>>>>>>
37052>>>>>        Send Request_Save of hoSessionDD
37053>>>>>        If (Err) Begin
37055>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37055>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37056>>>>>>
37056>>>>>            Function_Return ""
37057>>>>>        End
37057>>>>>>
37057>>>>>       
37057>>>>>        Function_Return sSessionKey        
37058>>>>>    End_Function
37059>>>>>    
37059>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37061>>>>>        DateTime dtLastAccess dtCurrent
37061>>>>>        TimeSpan tsDiff
37061>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37061>>>>>        Boolean bResult bCreatingNewSession
37061>>>>>        Boolean bLogWebSession bLoadWebApp
37061>>>>>        Integer eLoginMode
37061>>>>>        String sTime
37061>>>>>        Handle hoSessionDD hoUserDD       
37061>>>>>        
37061>>>>>        Move False to bLoadWebApp
37062>>>>>        If (num_arguments >= 2) Begin
37064>>>>>            Move bOptLoadWebApp to bLoadWebApp
37065>>>>>        End
37065>>>>>>
37065>>>>>        
37065>>>>>        Get phoSessionDD to hoSessionDD
37066>>>>>        Get phoUserDD to hoUserDD
37067>>>>>        
37067>>>>>        Get pbLogWebSession to bLogWebSession
37068>>>>>        Get peLoginMode to eLoginMode
37069>>>>>        
37069>>>>>        // for this object, you can only disable logging if login completely is disabled
37069>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37071>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37072>>>>>>
37072>>>>>            Function_Return False
37073>>>>>        End
37073>>>>>>
37073>>>>>
37073>>>>>        //  Clear session properties
37073>>>>>        Set psSessionKey to ""
37074>>>>>        Send UpdateSessionProperties True
37075>>>>>        
37075>>>>>        If not bLogWebSession Begin
37077>>>>>            Forward Get ValidateSession sSessionKey to bResult
37079>>>>>            Function_Return bResult
37080>>>>>        End        
37080>>>>>>
37080>>>>>        
37080>>>>>        Move False to bResult
37081>>>>>        Get piSessionTimeout to iSessionTimeout 
37082>>>>>        
37082>>>>>        //  Check if session exists
37082>>>>>        Send Clear of hoSessionDD
37083>>>>>        Move sSessionKey to WebAppSession.SessionKey
37084>>>>>        Send Find of hoSessionDD EQ Index.1
37085>>>>>            
37085>>>>>        If (Found) Begin
37087>>>>>            //  Calculate timespan between now and last access time
37087>>>>>            Move (CurrentDateTime()) to dtCurrent
37088>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37089>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37090>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37091>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37092>>>>>            
37092>>>>>            //  Check if session didn't time out
37092>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37094>>>>>                Forward Get ValidateSession sSessionKey to bResult
37096>>>>>                   
37096>>>>>                If (bResult) Begin
37098>>>>>                    //  Update session record
37098>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37099>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37100>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37101>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37102>>>>>                    Get Request_Validate of hoSessionDD to iErr
37103>>>>>                    If (iErr) Begin
37105>>>>>                        // this should not happen. If it does its a programming error
37105>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37106>>>>>>
37106>>>>>                        Function_Return False
37107>>>>>                    End
37107>>>>>>
37107>>>>>                    Send Request_Save of hoSessionDD
37108>>>>>                    
37108>>>>>                    //  Update user properties
37108>>>>>                    Send UpdateSessionProperties False
37109>>>>>                End
37109>>>>>>
37109>>>>>            End
37109>>>>>>
37109>>>>>            Else Begin
37110>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37110>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37111>>>>>                
37111>>>>>                If (not(bCreatingNewSession)) Begin
37113>>>>>                    If (not(bLoadWebApp)) Begin
37115>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37116>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37117>>>>>>
37117>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37118>>>>>                    End
37118>>>>>>
37118>>>>>                    Else Begin
37119>>>>>                        Set pbCreatingNewSession to True                    
37120>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37121>>>>>                        Set pbCreatingNewSession to False                        
37122>>>>>                    End
37122>>>>>>
37122>>>>>                End
37122>>>>>>
37122>>>>>            End
37122>>>>>>
37122>>>>>        End
37122>>>>>>
37122>>>>>        Else Begin
37123>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37124>>>>>>
37124>>>>>        End
37124>>>>>>
37124>>>>>        
37124>>>>>        Function_Return bResult
37125>>>>>    End_Function
