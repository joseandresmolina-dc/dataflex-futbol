37762>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37762>>>                Case Break
37763>>>
37763>>>            Case Else // must be nfUndefined
37763>>>
37763>>>        Case End
37763>>>
37763>>>        Send SetActionButtons
