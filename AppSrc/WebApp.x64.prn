37232>>>>>    Function IsLoggedIn Returns Boolean
37234>>>>>        String sLoginName
37234>>>>>        Boolean bLogWebSession bLoggedIn
37234>>>>>        
37234>>>>>        Get pbLogWebSession to bLogWebSession
37235>>>>>        If not bLogWebSession Begin
37237>>>>>            Forward Get IsLoggedIn to bLoggedIn
37239>>>>>            Function_Return bLoggedIn
37240>>>>>        End
37240>>>>>>
37240>>>>>        
37240>>>>>        Get psLoginName to sLoginName
37241>>>>>        
37241>>>>>        Function_Return (sLoginName <> "")
37242>>>>>    End_Function
37243>>>>>    
37243>>>>>    
37243>>>>>    //
37243>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37243>>>>>    // update properties based on the session and user data. Augment this function to update 
37243>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37243>>>>>    // the right records when this procedure is called.
37243>>>>>    //
37243>>>>>    // Params:
37243>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37243>>>>>    //
37243>>>>>    Procedure UpdateSessionProperties Boolean bClear
37245>>>>>        Handle hoUserDD
37245>>>>>        
37245>>>>>        Get phoUserDD to hoUserDD
37246>>>>>        
37246>>>>>        //  Update user properties
37246>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37248>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37249>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37250>>>>>            Set piUserRights to WebAppUser.Rights
37251>>>>>            
37251>>>>>            Send OnSessionPropertiesSet 
37252>>>>>        End
37252>>>>>>
37252>>>>>        Else Begin
37253>>>>>            Set psUsername to ""
37254>>>>>            Set psLoginName to ""
37255>>>>>            Set piUserRights to 0
37256>>>>>            
37256>>>>>            Send OnSessionPropertiesClear
37257>>>>>        End
37257>>>>>>
37257>>>>>    End_Procedure
37258>>>>>    
37258>>>>>    Procedure OnSessionPropertiesSet
37260>>>>>        //  Empty event stub
37260>>>>>    End_Procedure
37261>>>>>    
37261>>>>>    Procedure OnSessionPropertiesClear
37263>>>>>        //  Empty event stub
37263>>>>>    End_Procedure
37264>>>>>    
37264>>>>>    Procedure EndSession
37266>>>>>        Integer iErr
37266>>>>>        Boolean bLogWebSession
37266>>>>>        Handle hoSessionDD       
37266>>>>>        
37266>>>>>        Get phoSessionDD to hoSessionDD
37267>>>>>        Get pbLogWebSession to bLogWebSession
37268>>>>>        If not bLogWebSession Begin
37270>>>>>            Forward Send EndSession
37272>>>>>            Procedure_Return
37273>>>>>        End
37273>>>>>>
37273>>>>>            
37273>>>>>        //  Check if session exists
37273>>>>>        Send Clear of hoSessionDD
37274>>>>>        Get psSessionKey to WebAppSession.SessionKey
37275>>>>>        
37275>>>>>        Send Find of hoSessionDD EQ Index.1
37276>>>>>        If (Found) Begin
37278>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37279>>>>>            Get Request_Validate of hoSessionDD to iErr
37280>>>>>            If (iErr) Begin
37282>>>>>                // this should not happen. If it does its a programming error
37282>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37283>>>>>>
37283>>>>>                Procedure_Return
37284>>>>>            End
37284>>>>>>
37284>>>>>            Send Request_Save of hoSessionDD
37285>>>>>        End
37285>>>>>>
37285>>>>>    End_Procedure
37286>>>>>
37286>>>>>End_Class
