38304>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38304>>>                Case Break
38305>>>
38305>>>            Case Else // must be nfUndefined
38305>>>
38305>>>        Case End
38305>>>
38305>>>        Send SetActionButtons
