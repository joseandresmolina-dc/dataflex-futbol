37420>>>        Get StateHash of ghoWebApp to sPrevStateHash
37421>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37422>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37424>>>            WebSet psPrevStateHash to sPrevStateHash
37425>>>        End
37425>>>>
