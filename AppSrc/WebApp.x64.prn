37823>>>    Procedure SetActionButtons
37826>>>        tWebNavigateData NavigateData
37826>>>        tWebNavigateData NavigateData
37826>>>        Boolean bHasRecord
37826>>>        Handle hoDD
37826>>>
37826>>>        Get Server to hoDD
37827>>>        Get GetNavigateData to NavigateData
37828>>>        Get HasRecord of hoDD to bHasRecord
37829>>>
37829>>>        // let's hide all buttons and then Show the ones we want
37829>>>        WebSet pbRender of oEditBtn to False
37830>>>        WebSet pbRender of oSaveBtn to False
37831>>>        WebSet pbRender of oCancelChangesBtn to False
37832>>>        WebSet pbRender of oDeleteBtn to False
37833>>>
37833>>>        If (NavigateData.bReadOnly) Begin
37835>>>            WebSet pbRender of oEditBtn to True
37836>>>        End
37836>>>>
37836>>>        Else Begin
37837>>>            WebSet pbRender of oSaveBtn to True
37838>>>            WebSet pbRender of oCancelChangesBtn to True
37839>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37840>>>        End
37840>>>>
37840>>>    End_Procedure
