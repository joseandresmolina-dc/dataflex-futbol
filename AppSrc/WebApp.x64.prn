38263>>>    Procedure SetActionButtons
38266>>>        tWebNavigateData NavigateData
38266>>>        tWebNavigateData NavigateData
38266>>>        Boolean bHasRecord
38266>>>        Handle hoDD
38266>>>
38266>>>        Get Server to hoDD
38267>>>        Get GetNavigateData to NavigateData
38268>>>        Get HasRecord of hoDD to bHasRecord
38269>>>
38269>>>        // let's hide all buttons and then Show the ones we want
38269>>>        WebSet pbRender of oEditBtn to False
38270>>>        WebSet pbRender of oSaveBtn to False
38271>>>        WebSet pbRender of oCancelChangesBtn to False
38272>>>        WebSet pbRender of oDeleteBtn to False
38273>>>
38273>>>        If (NavigateData.bReadOnly) Begin
38275>>>            WebSet pbRender of oEditBtn to True
38276>>>        End
38276>>>>
38276>>>        Else Begin
38277>>>            WebSet pbRender of oSaveBtn to True
38278>>>            WebSet pbRender of oCancelChangesBtn to True
38279>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38280>>>        End
38280>>>>
38280>>>    End_Procedure
