38342>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38345>>>        WebSet pbRender of oNewButton to True
38346>>>        WebSet pbRender of oDetailButton to True
38347>>>
38347>>>        Case Begin
38347>>>            Case (NavigateData.eNavigateType = nfFromParent)
38349>>>                // If from parent, this is a constrained drill down
38349>>>                Case Break
38350>>>
38350>>>            Case (NavigateData.eNavigateType = nfFromChild)
38353>>>                // If from child, this is a probably a parent lookup from a Zoom
38353>>>                Case Break
38354>>>
38354>>>            Case (NavigateData.eNavigateType = nfFromMain)
38357>>>                // If from main, this is a probably a main-file lookup from a Zoom
38357>>>                WebSet pbRender of oDetailButton to False
38358>>>                Case Break
38359>>>
38359>>>            Case Else // must be nfUndefined
38359>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38359>>>
38359>>>        Case End
38359>>>
38359>>>    End_Procedure
38360>>>
38360>>>
38360>>>End_Object 
