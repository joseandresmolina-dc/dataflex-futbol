36980>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36981>>>>>    
36981>>>>>    Procedure Construct_Object
36983>>>>>        Handle hoObj
36983>>>>>        
36983>>>>>        Forward Send Construct_Object
36985>>>>>        
36985>>>>>        Set pbSessionCookieHttpOnly to True
36986>>>>>        
36986>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36987>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36988>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36989>>>>>        
36989>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36990>>>>>        Set phoUserDD to hoObj
36991>>>>>        
36991>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36992>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36993>>>>>        Set phoSessionDD to hoObj
36994>>>>>        
36994>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36995>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36996>>>>>        Set phoCrypto to hoObj
36997>>>>>        
36997>>>>>        Property Boolean pbPasswordHashing True
36998>>>>>        
36998>>>>>        Property Boolean pbCreatingNewSession False
36999>>>>>        Property String psLoginName
37000>>>>>        Property String psUserName ""
37001>>>>>        Property Integer piUserRights 0
37002>>>>>    End_Procedure
37003>>>>>    
37003>>>>>    Procedure End_Construct_Object
37005>>>>>        Forward Send End_Construct_Object
37007>>>>>        
37007>>>>>        Handle hoCrypto
37007>>>>>        Integer iFieldLen
37007>>>>>        If (pbPasswordHashing(Self)) Begin
37009>>>>>            Get phoCrypto to hoCrypto
37010>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
37013>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
37015>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
37016>>>>>>
37016>>>>>            End
37016>>>>>>
37016>>>>>        End
37016>>>>>>
37016>>>>>    End_Procedure
37017>>>>>    
37017>>>>>    Function CreateSession String sRemoteAddress Returns String
37019>>>>>        String sSessionKey
37019>>>>>        Integer iErr
37019>>>>>        Boolean bLogWebSession
37019>>>>>        Handle hoSessionDD       
37019>>>>>        Get phoSessionDD to hoSessionDD
37020>>>>>        
37020>>>>>        //  Get session key
37020>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
37022>>>>>        
37022>>>>>        Get pbLogWebSession to bLogWebSession
37023>>>>>        If not bLogWebSession Begin
37025>>>>>            Function_Return sSessionKey        
37026>>>>>        End
37026>>>>>>
37026>>>>>
37026>>>>>        //  Store session
37026>>>>>        Send Clear of hoSessionDD
37027>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
37028>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
37029>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
37030>>>>>        Get Request_Validate of hoSessionDD to iErr
37031>>>>>        If (iErr) Begin
37033>>>>>            // this should not happen. If it does its a programming error
37033>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37034>>>>>>
37034>>>>>            Function_Return ""
37035>>>>>        End
37035>>>>>>
37035>>>>>        Send Request_Save of hoSessionDD
37036>>>>>        If (Err) Begin
37038>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
37038>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
37039>>>>>>
37039>>>>>            Function_Return ""
37040>>>>>        End
37040>>>>>>
37040>>>>>       
37040>>>>>        Function_Return sSessionKey        
37041>>>>>    End_Function
37042>>>>>    
37042>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
37044>>>>>        DateTime dtLastAccess dtCurrent
37044>>>>>        TimeSpan tsDiff
37044>>>>>        Integer iErr iSessionTimeout iSpanMinutes
37044>>>>>        Boolean bResult bCreatingNewSession
37044>>>>>        Boolean bLogWebSession bLoadWebApp
37044>>>>>        Integer eLoginMode
37044>>>>>        String sTime
37044>>>>>        Handle hoSessionDD hoUserDD       
37044>>>>>        
37044>>>>>        Move False to bLoadWebApp
37045>>>>>        If (num_arguments >= 2) Begin
37047>>>>>            Move bOptLoadWebApp to bLoadWebApp
37048>>>>>        End
37048>>>>>>
37048>>>>>        
37048>>>>>        Get phoSessionDD to hoSessionDD
37049>>>>>        Get phoUserDD to hoUserDD
37050>>>>>        
37050>>>>>        Get pbLogWebSession to bLogWebSession
37051>>>>>        Get peLoginMode to eLoginMode
37052>>>>>        
37052>>>>>        // for this object, you can only disable logging if login completely is disabled
37052>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37054>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37055>>>>>>
37055>>>>>            Function_Return False
37056>>>>>        End
37056>>>>>>
37056>>>>>
37056>>>>>        //  Clear session properties
37056>>>>>        Set psSessionKey to ""
37057>>>>>        Send UpdateSessionProperties True
37058>>>>>        
37058>>>>>        If not bLogWebSession Begin
37060>>>>>            Forward Get ValidateSession sSessionKey to bResult
37062>>>>>            Function_Return bResult
37063>>>>>        End        
37063>>>>>>
37063>>>>>        
37063>>>>>        Move False to bResult
37064>>>>>        Get piSessionTimeout to iSessionTimeout 
37065>>>>>        
37065>>>>>        //  Check if session exists
37065>>>>>        Send Clear of hoSessionDD
37066>>>>>        Move sSessionKey to WebAppSession.SessionKey
37067>>>>>        Send Find of hoSessionDD EQ Index.1
37068>>>>>            
37068>>>>>        If (Found) Begin
37070>>>>>            //  Calculate timespan between now and last access time
37070>>>>>            Move (CurrentDateTime()) to dtCurrent
37071>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37072>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37073>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37074>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37075>>>>>            
37075>>>>>            //  Check if session didn't time out
37075>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37077>>>>>                Forward Get ValidateSession sSessionKey to bResult
37079>>>>>                   
37079>>>>>                If (bResult) Begin
37081>>>>>                    //  Update session record
37081>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37082>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37083>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37084>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37085>>>>>                    Get Request_Validate of hoSessionDD to iErr
37086>>>>>                    If (iErr) Begin
37088>>>>>                        // this should not happen. If it does its a programming error
37088>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37089>>>>>>
37089>>>>>                        Function_Return False
37090>>>>>                    End
37090>>>>>>
37090>>>>>                    Send Request_Save of hoSessionDD
37091>>>>>                    
37091>>>>>                    //  Update user properties
37091>>>>>                    Send UpdateSessionProperties False
37092>>>>>                End
37092>>>>>>
37092>>>>>            End
37092>>>>>>
37092>>>>>            Else Begin
37093>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37093>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37094>>>>>                
37094>>>>>                If (not(bCreatingNewSession)) Begin
37096>>>>>                    If (not(bLoadWebApp)) Begin
37098>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37099>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37100>>>>>>
37100>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37101>>>>>                    End
37101>>>>>>
37101>>>>>                    Else Begin
37102>>>>>                        Set pbCreatingNewSession to True                    
37103>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37104>>>>>                        Set pbCreatingNewSession to False                        
37105>>>>>                    End
37105>>>>>>
37105>>>>>                End
37105>>>>>>
37105>>>>>            End
37105>>>>>>
37105>>>>>        End
37105>>>>>>
37105>>>>>        Else Begin
37106>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37107>>>>>>
37107>>>>>        End
37107>>>>>>
37107>>>>>        
37107>>>>>        Function_Return bResult
37108>>>>>    End_Function
37109>>>>>    
37109>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37111>>>>>        If (not(pbPasswordHashing(Self))) Begin
37113>>>>>            Move sPassword to sHash
37114>>>>>            Function_Return True
37115>>>>>        End
37115>>>>>>
37115>>>>>        
37115>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37117>>>>>            Function_Return False
37118>>>>>        End
37118>>>>>>
37118>>>>>        Move ("V1$" + sHash) to sHash
37119>>>>>        Function_Return True
37120>>>>>    End_Function
37121>>>>>    
37121>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37123>>>>>        If (not(pbPasswordHashing(Self))) Begin
37125>>>>>            Move False to bShouldUpgrade
37126>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37127>>>>>        End
37127>>>>>>
37127>>>>>        
37127>>>>>        String sVersion
37127>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37128>>>>>        If (sVersion = "V1$") Begin
37130>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37133>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37134>>>>>        End
37134>>>>>>
37134>>>>>        Else Begin
37135>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37138>>>>>            Function_Return False
37139>>>>>        End
37139>>>>>>
37139>>>>>    End_Function
37140>>>>>    
37140>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37142>>>>>        Handle hoUserDD
37142>>>>>        Integer iErr
37142>>>>>        Get phoUserDD to hoUserDD
37143>>>>>        
37143>>>>>        //  Find the user
37143>>>>>        Send Clear of hoUserDD
37144>>>>>        Move sLoginName to WebAppUser.LoginName
37145>>>>>        Send Find of hoUserDD EQ Index.1
37146>>>>>        If (Found) Begin
37148>>>>>            Send Clear of hoUserDD
37149>>>>>            Function_Return False
37150>>>>>        End
37150>>>>>>
37150>>>>>        
37150>>>>>        Send Clear of hoUserDD
37151>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37152>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37153>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37155>>>>>            Send Clear of hoUserDD
37156>>>>>            Function_Return False
37157>>>>>        End
37157>>>>>>
37157>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37158>>>>>        Get Request_Validate of hoUserDD to iErr
37159>>>>>        If (iErr) Begin
37161>>>>>            Send Clear of hoUserDD
37162>>>>>            Function_Return False
37163>>>>>        End
37163>>>>>>
37163>>>>>        
37163>>>>>        Send Request_Save of hoUserDD
37164>>>>>        Function_Return (not(Err))
37165>>>>>    End_Function
37166>>>>>    
37166>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37168>>>>>        String sSessionKey sUserPassword
37168>>>>>        Handle hoSessionDD hoUserDD
37168>>>>>        Boolean bMatch bUpgrade
37168>>>>>        
37168>>>>>        Get phoSessionDD to hoSessionDD
37169>>>>>        Get phoUserDD to hoUserDD
37170>>>>>        Integer iErr eLoginMode
37170>>>>>        
37170>>>>>        // Refind session record
37170>>>>>        Get psSessionKey to sSessionKey
37171>>>>>        Send Clear of hoSessionDD
37172>>>>>        Move sSessionKey to WebAppSession.SessionKey
37173>>>>>        Send Find of hoSessionDD EQ Index.1
37174>>>>>        
37174>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37176>>>>>            Get peLoginMode to eLoginMode
37177>>>>>            
37177>>>>>            //  Find the user
37177>>>>>            Move sLoginName to WebAppUser.LoginName
37178>>>>>            Send Find of hoUserDD EQ Index.1
37179>>>>>            
37179>>>>>            // Check username and password
37179>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37181>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37182>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37183>>>>>                
37183>>>>>                If (bMatch) Begin
37185>>>>>                    // Store the login
37185>>>>>                    If (bUpgrade) Begin
37187>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37188>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37191>>>>>                    End
37191>>>>>>
37191>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37192>>>>>                    Get Request_Validate of hoSessionDD to iErr
37193>>>>>                    If (iErr) Begin
37195>>>>>                        // this should not happen. If it does its a programming error
37195>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37196>>>>>>
37196>>>>>                        Function_Return False
37197>>>>>                    End
37197>>>>>>
37197>>>>>                    
37197>>>>>                    Send Request_Save of hoSessionDD
37198>>>>>                    
37198>>>>>                    // Update session properties
37198>>>>>                    Send UpdateSessionProperties False
37199>>>>>                    Send NotifyChangeRights
37200>>>>>                    Function_Return True
37201>>>>>                End
37201>>>>>>
37201>>>>>                Else Begin
37202>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37202>>>>>                    Send Clear of hoUserDD
37203>>>>>                End
37203>>>>>>
37203>>>>>            End
37203>>>>>>
37203>>>>>            Else Begin
37204>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37204>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37205>>>>>            End
37205>>>>>>
37205>>>>>        End
37205>>>>>>
37205>>>>>        Else Begin
37206>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37206>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37207>>>>>        End
37207>>>>>>
37207>>>>>          
37207>>>>>        Function_Return False
37208>>>>>    End_Function
37209>>>>>    
37209>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37211>>>>>        Handle hoUserDD
37211>>>>>        Integer iErr
37211>>>>>        Get phoUserDD to hoUserDD
37212>>>>>        
37212>>>>>        //  Find the user
37212>>>>>        Send Clear of hoUserDD
37213>>>>>        Move sLoginName to WebAppUser.LoginName
37214>>>>>        Send Find of hoUserDD EQ Index.1
37215>>>>>        If (not(Found)) Begin
37217>>>>>            Send Clear of hoUserDD
37218>>>>>            Function_Return False
37219>>>>>        End
37219>>>>>>
37219>>>>>        
37219>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37221>>>>>            Send Clear of hoUserDD
37222>>>>>            Function_Return False
37223>>>>>        End
37223>>>>>>
37223>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37224>>>>>        Get Request_Validate of hoUserDD to iErr
37225>>>>>        If (iErr) Begin
37227>>>>>            Send Clear of hoUserDD
37228>>>>>            Function_Return False
37229>>>>>        End
37229>>>>>>
37229>>>>>        
37229>>>>>        Send Request_Save of hoUserDD
37230>>>>>        Function_Return (not(Err))
37231>>>>>    End_Function
