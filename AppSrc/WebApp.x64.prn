38298>>>    Procedure SetActionButtons
38301>>>        tWebNavigateData NavigateData
38301>>>        tWebNavigateData NavigateData
38301>>>        Boolean bHasRecord
38301>>>        Handle hoDD
38301>>>
38301>>>        Get Server to hoDD
38302>>>        Get GetNavigateData to NavigateData
38303>>>        Get HasRecord of hoDD to bHasRecord
38304>>>
38304>>>        // let's hide all buttons and then Show the ones we want
38304>>>        WebSet pbRender of oEditBtn to False
38305>>>        WebSet pbRender of oSaveBtn to False
38306>>>        WebSet pbRender of oCancelChangesBtn to False
38307>>>        WebSet pbRender of oDeleteBtn to False
38308>>>
38308>>>        If (NavigateData.bReadOnly) Begin
38310>>>            WebSet pbRender of oEditBtn to True
38311>>>        End
38311>>>>
38311>>>        Else Begin
38312>>>            WebSet pbRender of oSaveBtn to True
38313>>>            WebSet pbRender of oCancelChangesBtn to True
38314>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38315>>>        End
38315>>>>
38315>>>    End_Procedure
38316>>>
38316>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38319>>>        // Close after save
38319>>>        Send NavigateClose Self
38320>>>    End_Procedure
38321>>>
38321>>>    // this will close the view after a delete
38321>>>    Procedure OnViewDeleted Handle hoDDO
38324>>>        Send NavigateClose Self
38325>>>    End_Procedure
38326>>>
38326>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38329>>>        Case Begin
38329>>>            Case (NavigateData.eNavigateType = nfFromMain)
38331>>>                // If from main, this is a propbably a main file Select to Zoom.
38331>>>                Case Break
38332>>>
38332>>>            Case (NavigateData.eNavigateType = nfFromParent)
38335>>>                // If from parent, this is a constrained drill down.
38335>>>                Case Break
38336>>>
38336>>>            Case (NavigateData.eNavigateType = nfFromChild)
38339>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38339>>>                Case Break
38340>>>
38340>>>            Case Else // must be nfUndefined
38340>>>
38340>>>        Case End
38340>>>
38340>>>        Send SetActionButtons
38341>>>
38341>>>    End_Procedure
38342>>>
38342>>>End_Object 
