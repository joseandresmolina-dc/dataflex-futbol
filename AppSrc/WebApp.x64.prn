36649>>>>>>>    //
36649>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36649>>>>>>>    //
36649>>>>>>>    //  Params:
36649>>>>>>>    //      dtTime  Time to convert
36649>>>>>>>    //  Returns:
36649>>>>>>>    //      String with "HH:MM:SS" format
36649>>>>>>>    //
36649>>>>>>>    Function TimeToString DateTime dtTime Returns String
36651>>>>>>>        String sHours sMinutes sSeconds
36651>>>>>>>        
36651>>>>>>>        //  Extract parts
36651>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36652>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36653>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36654>>>>>>>        
36654>>>>>>>        //  Fill out with 0
36654>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36657>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36660>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36663>>>>>>>        
36663>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36664>>>>>>>    End_Function
36665>>>>>>>    
36665>>>>>>>    //
36665>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36665>>>>>>>    //
36665>>>>>>>    //  Params:
36665>>>>>>>    //      dtTime  Datetime variable to add time to
36665>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36665>>>>>>>    //  Returns:
36665>>>>>>>    //      dtDateTime with the loaded time
36665>>>>>>>    //
36665>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36667>>>>>>>        String sHours sMinutes sSeconds
36667>>>>>>>        
36667>>>>>>>        //  Extract parts
36667>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36668>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36669>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36670>>>>>>>        
36670>>>>>>>        //  Set to DateTime
36670>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36671>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36672>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36673>>>>>>>        
36673>>>>>>>        Function_Return dtTime
36674>>>>>>>    End_Function
