37832>>>    // Evento de la vista para preguntar qué se hace al llegar la vista       
37832>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37835>>>        Case Begin
37835>>>            Case (NavigateData.eNavigateType = nfFromMain)
37837>>>                // If from main, this is a propbably a main file Select to Zoom.
37837>>>                Case Break
37838>>>
37838>>>            Case (NavigateData.eNavigateType = nfFromParent)
37841>>>                // If from parent, this is a constrained drill down.
37841>>>                Case Break
37842>>>
37842>>>            Case (NavigateData.eNavigateType = nfFromChild)
37845>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37845>>>                Case Break
37846>>>
37846>>>            Case Else // must be nfUndefined
37846>>>
37846>>>        Case End
37846>>>
37846>>>        Send SetActionButtons
37847>>>        
37847>>>        /* Esto es lo que se pone por defecto en un zoom: Si he venido al zoomEntrenador, seleccionando un entrenador ponme el nombre,         si no hay un record es que vienes de viewnewrecord por lo tanto pon Nuevo entrenador */
37847>>>        If (HasRecord(Server(Self))) Begin
37849>>>            Send SetHeaderCaption   ("Entrenador:"*entrenador.Nombre)
37850>>>            Send SetBreadcrumbCaption entrenador.Nombre
37851>>>        End
37851>>>>
37851>>>        Else Begin
37852>>>            Send SetHeaderCaption   "Nuevo entrenador"
37853>>>            Send SetBreadcrumbCaption "Nuevo"
37854>>>        End 
37854>>>>
37854>>>    End_Procedure
37855>>>
37855>>>End_Object 
