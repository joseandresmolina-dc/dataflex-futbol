37752>>>
37752>>>        // let's hide all buttons and then Show the ones we want
37752>>>        WebSet pbRender of oEditBtn to False
37753>>>        WebSet pbRender of oSaveBtn to False
37754>>>        WebSet pbRender of oCancelChangesBtn to False
37755>>>        WebSet pbRender of oDeleteBtn to False
37756>>>
37756>>>        If (NavigateData.bReadOnly) Begin
37758>>>            WebSet pbRender of oEditBtn to True
37759>>>        End
37759>>>>
37759>>>        Else Begin
37760>>>            WebSet pbRender of oSaveBtn to True
37761>>>            WebSet pbRender of oCancelChangesBtn to True
37762>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37763>>>        End
