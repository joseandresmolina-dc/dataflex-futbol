36683>>>>>>>    //
36683>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36683>>>>>>>    //
36683>>>>>>>    //  Params:
36683>>>>>>>    //      dtTime  Time to convert
36683>>>>>>>    //  Returns:
36683>>>>>>>    //      String with "HH:MM:SS" format
36683>>>>>>>    //
36683>>>>>>>    Function TimeToString DateTime dtTime Returns String
36685>>>>>>>        String sHours sMinutes sSeconds
36685>>>>>>>        
36685>>>>>>>        //  Extract parts
36685>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36686>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36687>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36688>>>>>>>        
36688>>>>>>>        //  Fill out with 0
36688>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36691>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36694>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36697>>>>>>>        
36697>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36698>>>>>>>    End_Function
36699>>>>>>>    
36699>>>>>>>    //
36699>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36699>>>>>>>    //
36699>>>>>>>    //  Params:
36699>>>>>>>    //      dtTime  Datetime variable to add time to
36699>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36699>>>>>>>    //  Returns:
36699>>>>>>>    //      dtDateTime with the loaded time
36699>>>>>>>    //
36699>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36701>>>>>>>        String sHours sMinutes sSeconds
36701>>>>>>>        
36701>>>>>>>        //  Extract parts
36701>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36702>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36703>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36704>>>>>>>        
36704>>>>>>>        //  Set to DateTime
36704>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36705>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36706>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36707>>>>>>>        
36707>>>>>>>        Function_Return dtTime
36708>>>>>>>    End_Function
