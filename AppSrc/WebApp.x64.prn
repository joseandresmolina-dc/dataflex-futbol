36666>>>>>>>    //
36666>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36666>>>>>>>    //
36666>>>>>>>    //  Params:
36666>>>>>>>    //      dtTime  Time to convert
36666>>>>>>>    //  Returns:
36666>>>>>>>    //      String with "HH:MM:SS" format
36666>>>>>>>    //
36666>>>>>>>    Function TimeToString DateTime dtTime Returns String
36668>>>>>>>        String sHours sMinutes sSeconds
36668>>>>>>>        
36668>>>>>>>        //  Extract parts
36668>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36669>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36670>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36671>>>>>>>        
36671>>>>>>>        //  Fill out with 0
36671>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36674>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36677>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36680>>>>>>>        
36680>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36681>>>>>>>    End_Function
36682>>>>>>>    
36682>>>>>>>    //
36682>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36682>>>>>>>    //
36682>>>>>>>    //  Params:
36682>>>>>>>    //      dtTime  Datetime variable to add time to
36682>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36682>>>>>>>    //  Returns:
36682>>>>>>>    //      dtDateTime with the loaded time
36682>>>>>>>    //
36682>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36684>>>>>>>        String sHours sMinutes sSeconds
36684>>>>>>>        
36684>>>>>>>        //  Extract parts
36684>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36685>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36686>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36687>>>>>>>        
36687>>>>>>>        //  Set to DateTime
36687>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36688>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36689>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36690>>>>>>>        
36690>>>>>>>        Function_Return dtTime
36691>>>>>>>    End_Function
