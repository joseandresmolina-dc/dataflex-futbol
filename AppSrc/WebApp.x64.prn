38262>>>        tWebNavigateData NavigateData
38262>>>        tWebNavigateData NavigateData
38262>>>        Boolean bHasRecord
38262>>>        Handle hoDD
38262>>>
38262>>>        Get Server to hoDD
38263>>>        Get GetNavigateData to NavigateData
38264>>>        Get HasRecord of hoDD to bHasRecord
38265>>>
38265>>>        // let's hide all buttons and then Show the ones we want
38265>>>        WebSet pbRender of oEditBtn to False
38266>>>        WebSet pbRender of oSaveBtn to False
38267>>>        WebSet pbRender of oCancelChangesBtn to False
38268>>>        WebSet pbRender of oDeleteBtn to False
38269>>>
38269>>>        If (NavigateData.bReadOnly) Begin
38271>>>            WebSet pbRender of oEditBtn to True
38272>>>        End
38272>>>>
38272>>>        Else Begin
38273>>>            WebSet pbRender of oSaveBtn to True
38274>>>            WebSet pbRender of oCancelChangesBtn to True
38275>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38276>>>        End
38276>>>>
38276>>>    End_Procedure
