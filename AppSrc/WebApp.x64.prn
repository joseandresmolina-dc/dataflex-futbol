37804>>>    Procedure SetActionButtons
37807>>>        tWebNavigateData NavigateData
37807>>>        tWebNavigateData NavigateData
37807>>>        Boolean bHasRecord
37807>>>        Handle hoDD
37807>>>
37807>>>        Get Server to hoDD
37808>>>        Get GetNavigateData to NavigateData
37809>>>        Get HasRecord of hoDD to bHasRecord
37810>>>
37810>>>        // let's hide all buttons and then Show the ones we want
37810>>>        WebSet pbRender of oEditBtn to False
37811>>>        WebSet pbRender of oSaveBtn to False
37812>>>        WebSet pbRender of oCancelChangesBtn to False
37813>>>        WebSet pbRender of oDeleteBtn to False
37814>>>
37814>>>        If (NavigateData.bReadOnly) Begin
37816>>>            WebSet pbRender of oEditBtn to True
37817>>>        End
37817>>>>
37817>>>        Else Begin
37818>>>            WebSet pbRender of oSaveBtn to True
37819>>>            WebSet pbRender of oCancelChangesBtn to True
37820>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37821>>>        End
37821>>>>
37821>>>    End_Procedure
