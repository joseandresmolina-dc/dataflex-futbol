37851>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37854>>>        Case Begin
37854>>>            Case (NavigateData.eNavigateType = nfFromMain)
37856>>>                // If from main, this is a propbably a main file Select to Zoom.
37856>>>                Case Break
37857>>>
37857>>>            Case (NavigateData.eNavigateType = nfFromParent)
37860>>>                // If from parent, this is a constrained drill down.
37860>>>                Case Break
37861>>>
37861>>>            Case (NavigateData.eNavigateType = nfFromChild)
37864>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37864>>>                Case Break
37865>>>
37865>>>            Case Else // must be nfUndefined
37865>>>
37865>>>        Case End
37865>>>
37865>>>        Send SetActionButtons
37866>>>        
37866>>>        If (HasRecord(Server(Self))) Begin
37868>>>            Send SetHeaderCaption   ("Entrenador:"*entrenador.Nombre)
37869>>>            Send SetBreadcrumbCaption entrenador.Nombre
37870>>>        End
37870>>>>
37870>>>        Else Begin
37871>>>            Send SetHeaderCaption   "Nuevo entrenador"
37872>>>            Send SetBreadcrumbCaption "Nuevo"
37873>>>        End 
37873>>>>
37873>>>    End_Procedure
